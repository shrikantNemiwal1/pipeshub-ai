{
    "compilerOptions": {
      "target": "es5",
      "downlevelIteration": true,
      "lib": ["dom", "dom.iterable", "es6"],
      "allowJs": true,
      "skipLibCheck": true,
      "strict": false,
      "forceConsistentCasingInFileNames": true,
      "noEmit": true,
      "esModuleInterop": true,
      "module": "esnext",
      "moduleResolution": "bundler",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "jsx": "preserve",
      "incremental": true,
      "plugins": [
        {
          "name": "next"
        }
      ],
      "baseUrl": ".",
      "paths": {
        "@/*": ["./*"],
        "@/chat/*": ["./app/(main)/chat/*"],
        "@/knowledge-base/*": ["./app/(main)/knowledge-base/*"],
        "@/workspace/*": ["./app/(main)/workspace/*"]
      }
    },
    "include": [
      "next-env.d.ts",
      "**/*.ts",
      "**/*.tsx",
      ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules", "electron", "**/__tests__/**"]
  }
