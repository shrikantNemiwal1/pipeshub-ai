{
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.d.ts",
    "src/integrations/**",
    "src/modules/api-docs/docs.routes.ts",
    "src/modules/user_management/types/user_management.types.ts",
    "src/modules/notification/types/types.ts"
  ],
  "reporter": ["text", "lcov", "html"],
  "report-dir": "coverage",
  "check-coverage": true,
  "lines": 90,
  "functions": 90,
  "branches": 80,
  "statements": 90,
  "temp-directory": ".c8_output"
}
